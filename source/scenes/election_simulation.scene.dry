Q.new_middle_sap = 5;
Q.new_middle_kpd = 0;
Q.new_middle_z = 10;
Q.new_middle_lib= 25;
Q.new_middle_dvp = 25;
Q.new_middle_avf = 10;
Q.new_middle_nsdap = 5;

Q.farmowners_sap = 10;
Q.farmowners_kpd = 0;
Q.farmowners_z = 5;
Q.farmowners_lib= 5;
Q.farmowners_dvp = 15;
Q.farmowners_avf = 45;
Q.farmowners_nsdap = 5;

Q.peasants_sap = 25;
Q.peasants_kpd = 55;
Q.peasants_z = 1;
Q.peasants_lib = 0;
Q.peasants_dvp = 0;
Q.peasants_avf = 5;
Q.peasants_nsdap = 15;

Q.industrialists_and_aristocrats_sap = 15;
Q.industrialists_and_aristocrats_kpd = 5;
Q.industrialists_and_aristocrats_z = 50;
Q.industrialists_and_aristocrats_lib = 0;
Q.industrialists_and_aristocrats_dvp = 5;
Q.industrialists_and_aristocrats_avf = 5;
Q.industrialists_and_aristocrats_nsdap = 0;

!}
